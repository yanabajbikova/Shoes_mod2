<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ShoesApp.MainWindow"
        Title="ООО Обувь - Авторизация"
        Width="400" Height="550"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF"
        RequestedThemeVariant="Light"
        FontFamily="Times New Roman">

    <Window.Styles>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#00D683" />
            <Setter Property="TextBlock.Foreground" Value="Black" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *, Auto">
        <Border Grid.Row="0" Background="#7FFF00" Height="5"/>

        <StackPanel Grid.Row="1" Margin="40,20" Spacing="15" VerticalAlignment="Center">
            
            <StackPanel Spacing="10" Margin="0,0,0,10">
                
                <TextBlock Text="ООО ОБУВЬ" FontSize="22" FontWeight="Bold" 
                           HorizontalAlignment="Center" Foreground="Black"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Логин:" FontWeight="Bold" Foreground="Black" Margin="2,0"/>
                <TextBox x:Name="LoginBox" 
                         Watermark="Введите ваш логин" 
                         Height="40" 
                         Background="#F9F9F9"
                         BorderBrush="#CCCCCC"
                         VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Пароль:" FontWeight="Bold" Foreground="Black" Margin="2,0"/>
                <TextBox x:Name="PasswordBox" 
                         Watermark="Введите ваш пароль" 
                         PasswordChar="*" 
                         Height="40" 
                         Background="#F9F9F9"
                         BorderBrush="#CCCCCC"
                         VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Spacing="10" Margin="0,15,0,0">
                <Button Content="ВОЙТИ" 
                        Click="OnLoginClick" 
                        Background="#00FA9A" 
                        Foreground="Black" 
                        Height="45" 
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Center" 
                        VerticalContentAlignment="Center"
                        FontWeight="Bold" 
                        CornerRadius="5"
                        BorderThickness="0"/>
                
                <Button Content="Войти как гость" 
                        Click="OnGuestClick" 
                        Background="Transparent" 
                        Foreground="#555555" 
                        BorderBrush="#CCCCCC" 
                        BorderThickness="1"
                        Height="40" 
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Center" 
                        VerticalContentAlignment="Center"
                        CornerRadius="5"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2" Background="#7FFF00" Height="30">
            <TextBlock Text="Форма авторизации" FontSize="11" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black"/>
        </Border>
    </Grid>
</Window>